# Copy to ``.env`` in this directory (gitignored). Adjust for your machine.

DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/dbname
SESSION_SECRET=change-me

# Primary demo user (full access) — set email + password for seeds
DEMO_PRIMARY_EMAIL=
DEMO_SEED_PASSWORD=

# View-only portfolio login (documented defaults; mirror primary after seed)
DEMO_VIEWER_EMAIL=viewers@example.com
DEMO_VIEWER_PASSWORD=Viewer1!
